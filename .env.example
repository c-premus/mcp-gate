# mcp-gate configuration
# Copy to .env and fill in values for your environment.

# Required
LISTEN_ADDR=0.0.0.0:8080
UPSTREAM_URL=http://mcp-server:8000
RESOURCE_URI=https://mcp.example.com
AUTHORIZATION_SERVER=https://auth.example.com/application/o/mcp/
JWKS_URI=https://auth.example.com/application/o/mcp/jwks/
EXPECTED_ISSUER=https://auth.example.com/application/o/mcp/
EXPECTED_AUDIENCE=your-oauth-client-id

# Optional
# REQUIRED_SCOPES=openid
# SCOPES_SUPPORTED=openid,profile
# RESOURCE_NAME=MCP Server
# LOG_LEVEL=info
# TRUSTED_PROXIES=172.20.0.0/16
# METRICS_ADDR=:9090
# OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
